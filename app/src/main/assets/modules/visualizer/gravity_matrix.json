{
  "id": "gravityMatrix",
  "type": "visualizer",
  "name": "Gravity Matrix",
  "version": "1.0.0",
  "description": "A character grid that reacts to physics and motion.",
  "active": false,
  "data": {
    "rendererScript": "GravityMatrixRenderer",
    "settings": {
      "fadeSpeed": 0.25,
      "gravityStrength": 0.2,
      "friction": 0.97,

      "//": ">>> НОВЫЙ БЛОК НАСТРОЕК ГИРОСКОПА <<<",
      "tiltPhysics": {
        "enabled": true,
        "strength": 0.2,       // Сила гравитации
        "invertPitch": false,  // false = наклон "на себя" заставляет падать "вниз" по экрану (к пользователю)
        "invertRoll": false    // false = наклон вправо заставляет падать вправо
      },

      "touchPushRadius": 150,
      "touchPushStrength": 1.5,
      "glitchColors": [
        "#61dca3",
        "#61b3dc",
        "#ffffff"
      ]
    }
  }
}